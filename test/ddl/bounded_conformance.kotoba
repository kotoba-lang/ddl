(ns ddl.bounded-conformance
  (:require [ddl.bounded-validate :as bounded])
  (:export [main summary-check reject-check]))

(def summary-type
  [:record :ddl/bounded-validation-summary
   [[:error-count :i64] [:warning-count :i64] [:valid-flag :i64]]])
(def validation-result-type [:result [:alias summary-type] :keyword])

(defn summary-check
  [data :vector-i64 expected-errors :i64 expected-warnings :i64 expected-valid :i64]
  :i64
  (match-result (bounded/validate data) validation-result-type
    (ok actual
      (if (= expected-errors (record-get summary-type actual :error-count))
        (if (= expected-warnings (record-get summary-type actual :warning-count))
          (if (= expected-valid (record-get summary-type actual :valid-flag)) 42 3) 2) 1))
    (err reason 9)))

(defn reject-check [data :vector-i64] :i64
  (match-result (bounded/validate data) validation-result-type
    (ok actual 1)
    (err reason 42)))

(defn main [] :i64 42)
