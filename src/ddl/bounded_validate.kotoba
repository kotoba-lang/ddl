(ns ddl.bounded-validate
  (:export [validate]))

(def summary-type
  [:record :ddl/bounded-validation-summary
   [[:error-count :i64] [:warning-count :i64] [:valid-flag :i64]]])
(def validation-result-type [:result [:alias summary-type] :keyword])

(defn fail [reason :keyword] [:alias validation-result-type]
  (result-err-of validation-result-type reason))

(defn table-offset [index :i64] :i64 (+ 3 (* index 2)))
(defn column-base [tables :i64] :i64 (+ 3 (* tables 2)))
(defn column-offset [tables :i64 index :i64] :i64
  (+ (column-base tables) (* index 3)))
(defn fk-base [tables :i64 columns :i64] :i64
  (+ (column-base tables) (* columns 3)))
(defn fk-offset [tables :i64 columns :i64 index :i64] :i64
  (+ (fk-base tables columns) (* index 2)))
(defn table-id [data :vector-i64 index :i64] :i64
  (vector-at data (table-offset index)))
(defn table-pk [data :vector-i64 index :i64] :i64
  (vector-at data (+ (table-offset index) 1)))
(defn column-table [data :vector-i64 tables :i64 index :i64] :i64
  (vector-at data (column-offset tables index)))
(defn column-id [data :vector-i64 tables :i64 index :i64] :i64
  (vector-at data (+ (column-offset tables index) 1)))
(defn column-type-flag [data :vector-i64 tables :i64 index :i64] :i64
  (vector-at data (+ (column-offset tables index) 2)))
(defn fk-owner [data :vector-i64 tables :i64 columns :i64 index :i64] :i64
  (vector-at data (fk-offset tables columns index)))
(defn fk-reference [data :vector-i64 tables :i64 columns :i64 index :i64] :i64
  (vector-at data (+ (fk-offset tables columns index) 1)))

(defn table-exists?
  [data :vector-i64 tables :i64 wanted :i64 index :i64] :bool
  (if (= index tables) false
    (if (= wanted (table-id data index)) true
      (table-exists? data tables wanted (+ index 1)))))

(defn valid-tables? [data :vector-i64 tables :i64 index :i64] :bool
  (if (= index tables) true
    (let [id (table-id data index) pk (table-pk data index)]
      (if (< id 0) false
        (if (or (< pk 0) (> pk 1)) false
          (valid-tables? data tables (+ index 1)))))))

(defn unique-tables?
  [data :vector-i64 tables :i64 left :i64 right :i64] :bool
  (if (= left tables) true
    (if (= right tables) (unique-tables? data tables (+ left 1) (+ left 2))
      (if (= (table-id data left) (table-id data right)) false
        (unique-tables? data tables left (+ right 1))))))

(defn valid-columns?
  [data :vector-i64 tables :i64 columns :i64 index :i64] :bool
  (if (= index columns) true
    (let [owner (column-table data tables index)
          id (column-id data tables index)
          type-flag (column-type-flag data tables index)]
      (if (< id 0) false
        (if (or (< type-flag 0) (> type-flag 1)) false
          (if (table-exists? data tables owner 0)
            (valid-columns? data tables columns (+ index 1)) false))))))

(defn valid-fks?
  [data :vector-i64 tables :i64 columns :i64 fks :i64 index :i64] :bool
  (if (= index fks) true
    (let [owner (fk-owner data tables columns index)
          reference (fk-reference data tables columns index)]
      (if (< reference 0) false
        (if (table-exists? data tables owner 0)
          (valid-fks? data tables columns fks (+ index 1)) false)))))

(defn duplicate-column-errors
  [data :vector-i64 tables :i64 columns :i64 left :i64 right :i64] :i64
  (if (= left columns) 0
    (if (= right columns)
      (duplicate-column-errors data tables columns (+ left 1) (+ left 2))
      (+ (if (= (column-table data tables left) (column-table data tables right))
           (if (= (column-id data tables left) (column-id data tables right)) 1 0) 0)
         (duplicate-column-errors data tables columns left (+ right 1))))))

(defn empty-type-errors
  [data :vector-i64 tables :i64 columns :i64 index :i64] :i64
  (if (= index columns) 0
    (+ (if (= (column-type-flag data tables index) 0) 1 0)
       (empty-type-errors data tables columns (+ index 1)))))

(defn no-pk-warnings [data :vector-i64 tables :i64 index :i64] :i64
  (if (= index tables) 0
    (+ (if (= (table-pk data index) 0) 1 0)
       (no-pk-warnings data tables (+ index 1)))))

(defn dangling-fk-errors
  [data :vector-i64 tables :i64 columns :i64 fks :i64 index :i64] :i64
  (if (= index fks) 0
    (+ (if (table-exists? data tables
             (fk-reference data tables columns index) 0) 0 1)
       (dangling-fk-errors data tables columns fks (+ index 1)))))

(defn finish [data :vector-i64 tables :i64 columns :i64 fks :i64]
  [:alias validation-result-type]
  (let [errors (+ (duplicate-column-errors data tables columns 0 1)
                  (empty-type-errors data tables columns 0)
                  (dangling-fk-errors data tables columns fks 0))
        warnings (no-pk-warnings data tables 0)]
    (result-ok-of validation-result-type
      (record summary-type errors warnings (if (= errors 0) 1 0)))))

(defn validate [data :vector-i64] [:alias validation-result-type]
  (if (< (vector-count data) 3) (fail :truncated-header)
    (let [tables (vector-at data 0)
          columns (vector-at data 1)
          fks (vector-at data 2)]
      (if (or (< tables 0) (> tables 3)) (fail :table-count-out-of-range)
        (if (or (< columns 0) (> columns 4)) (fail :column-count-out-of-range)
          (if (or (< fks 0) (> fks 2)) (fail :foreign-key-count-out-of-range)
            (if (= (vector-count data) (+ 3 (* tables 2) (* columns 3) (* fks 2)))
              (if (valid-tables? data tables 0)
                (if (unique-tables? data tables 0 1)
                  (if (valid-columns? data tables columns 0)
                    (if (valid-fks? data tables columns fks 0)
                      (finish data tables columns fks)
                      (fail :invalid-foreign-key-encoding))
                    (fail :invalid-column-encoding))
                  (fail :duplicate-table-id))
                (fail :invalid-table-encoding))
              (fail :malformed-length))))))))
